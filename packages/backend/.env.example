PORT=8080
DATABASE_URL="postgresql://clawster:secret@localhost:5432/clawster"
JWT_SECRET="change-me-to-a-random-secret"
MASTER_KEY="change-me-to-32-bytes-hex-key"
NODE_ENV=development

# Local media storage directory (defaults to <cwd>/data/media if unset).
# In production, mount a persistent volume at this path so uploads survive redeploys.
# MEDIA_ROOT=/data/media

# AI integration (optional — chatbot features disabled when unset)
# CHAT_BASE_URL=https://api.ilmu.ai/v1
# CHAT_API_KEY=sk-...
# CHAT_MODEL=nemo-super
