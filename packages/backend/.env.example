PORT=8080
DATABASE_URL="postgresql://clawster:secret@localhost:5432/clawster"
JWT_SECRET="change-me-to-a-random-secret"
MASTER_KEY="change-me-to-32-bytes-hex-key"
NODE_ENV=development

# MinIO (S3-compatible object storage)
# Local dev: docker compose up -d → API on 8081, console on 8082
# Production: set MINIO_ENDPOINT to your Coolify MinIO service URL
MINIO_ENDPOINT=http://localhost:8081
MINIO_ROOT_USER=clawster
MINIO_ROOT_PASSWORD=supersecret123!
MINIO_BUCKET=clawster
MINIO_REGION=ap-southeast-5
